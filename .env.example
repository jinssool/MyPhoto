# Public app label only. Do not put secrets in NEXT_PUBLIC_* values.
NEXT_PUBLIC_APP_NAME="Family Memory Gallery"

# Future server-only placeholders. Leave empty until Drive/Supabase tasks.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_DRIVE_SCOPES="https://www.googleapis.com/auth/drive.readonly"

# Server-only token encryption key for local Drive OAuth tokens.
# Generate a 32-byte base64 key with: openssl rand -base64 32
# Put the generated value in .env.local as TOKEN_ENCRYPTION_KEY.
# Never commit .env.local, and never prefix this key with NEXT_PUBLIC_.
TOKEN_ENCRYPTION_KEY=

# Server-side metadata reads use the public anon key.
# Never put privileged Supabase keys in this file or in client code.
SUPABASE_URL=
SUPABASE_ANON_KEY=
